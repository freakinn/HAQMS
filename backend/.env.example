PORT=5000
# If port 5000 is already occupied locally, set PORT=5001 and set
# frontend/.env.local NEXT_PUBLIC_API_BASE_URL="http://localhost:5001/api".
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/haqms?schema=public"
JWT_SECRET="replace-with-a-random-32-plus-character-secret"
JWT_EXPIRES_IN="15m"
JWT_ISSUER="haqms-api"
JWT_AUDIENCE="haqms-web"
NODE_ENV="development"
